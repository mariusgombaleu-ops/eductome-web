rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Owner: full read/write
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Public read (pour /parent/:uid) est désormais géré par la Cloud Function
      // getPublicStudentData qui n'expose que les champs sûrs via Admin SDK.
      // La règle "allow read: if true" a été fermée (FIX 5 — sécurité données).

      // ── achats ──────────────────────────────────────────────────────────────
      // Writes come from Cloud Functions (admin SDK bypasses rules).
      match /achats/{achatId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // ── timetable ───────────────────────────────────────────────────────────
      match /timetable/{slotId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── assessments ─────────────────────────────────────────────────────────
      match /assessments/{assessmentId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ─── relais ───────────────────────────────────────────────────────────────
    match /relais/{code} {
      // Any authenticated user can read (code validation at purchase flow)
      allow read: if request.auth != null;
      // Write: admin custom claim only
      allow write: if request.auth != null && request.auth.token.isAdmin == true;

      // ── ventes ──────────────────────────────────────────────────────────────
      // Writes come from Cloud Functions (admin SDK bypasses rules).
      match /ventes/{venteId} {
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/relais/$(code)).data.uid == request.auth.uid;
        allow write: if false;
      }
    }

    // ─── examResults ──────────────────────────────────────────────────────────
    // Managed exclusively by Cloud Functions — deny all client access.
    match /examResults/{document=**} {
      allow read, write: if false;
    }

    // ─── forum_posts ──────────────────────────────────────────────────────────
    match /forum_posts/{postId} {
      // Lire : tout utilisateur authentifié
      allow read: if request.auth != null;
      // Créer : tout utilisateur authentifié (auteur = request.auth.uid)
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      // Modifier/Supprimer : seulement l'auteur ou un admin
      allow update, delete: if request.auth != null
                            && (resource.data.authorId == request.auth.uid
                                || request.auth.token.isAdmin == true);
    }

    // ─── forum_replies ────────────────────────────────────────────────────────
    match /forum_replies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && (resource.data.authorId == request.auth.uid
                                || request.auth.token.isAdmin == true);
    }

    // ─── Default ──────────────────────────────────────────────────────────────
    // Firestore denies by default; all unlisted collections are implicitly denied.
  }
}
