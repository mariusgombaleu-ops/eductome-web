rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Owner : lecture totale de son propre profil
      allow read: if request.auth != null && request.auth.uid == uid;

      // Owner : écriture autorisée SAUF les champs sensibles contrôlés par les Cloud Functions.
      // unlockedCourses, unlockedBadges et rewardedActions ne peuvent être modifiés
      // que via Admin SDK (Cloud Functions) qui bypass ces règles.
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['unlockedCourses', 'unlockedBadges', 'rewardedActions']);

      // Création du profil (premier setDoc à l'inscription) — autorisée
      allow create: if request.auth != null && request.auth.uid == uid;

      // ── achats ──────────────────────────────────────────────────────────────
      // Writes come from Cloud Functions (admin SDK bypasses rules).
      match /achats/{achatId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // ── timetable ───────────────────────────────────────────────────────────
      match /timetable/{slotId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── assessments ─────────────────────────────────────────────────────────
      match /assessments/{assessmentId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── notifications ────────────────────────────────────────────────────────
      // Écriture uniquement via Cloud Functions (Admin SDK).
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        // Autoriser la mise à jour du champ "read" uniquement (marquer comme lu)
        allow update: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if false;
      }
    }

    // ─── relais ───────────────────────────────────────────────────────────────
    match /relais/{code} {
      // Any authenticated user can read (code validation at purchase flow)
      allow read: if request.auth != null;
      // Write: admin custom claim only
      allow write: if request.auth != null && request.auth.token.isAdmin == true;

      // ── ventes ──────────────────────────────────────────────────────────────
      // Writes come from Cloud Functions (admin SDK bypasses rules).
      match /ventes/{venteId} {
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/relais/$(code)).data.uid == request.auth.uid;
        allow write: if false;
      }
    }

    // ─── examResults ──────────────────────────────────────────────────────────
    // Managed exclusively by Cloud Functions — deny all client access.
    match /examResults/{document=**} {
      allow read, write: if false;
    }

    // ─── _ratelimit ───────────────────────────────────────────────────────────
    // Collection interne pour le rate limiting des Cloud Functions.
    // Aucun accès client direct.
    match /_ratelimit/{document=**} {
      allow read, write: if false;
    }

    // ─── _metadata ────────────────────────────────────────────────────────────
    // Métadonnées internes (polling Selar, etc.) — aucun accès client.
    match /_metadata/{document=**} {
      allow read, write: if false;
    }

    // ─── achats (racine) ──────────────────────────────────────────────────────
    // Collection racine des achats — écrite par les Cloud Functions (Admin SDK).
    // Le frontend lit via onSnapshot pour afficher les cours débloqués.
    // SÉCURITÉ : lecture restreinte au propriétaire via compte_id.
    match /achats/{achatId} {
      allow read: if request.auth != null
                   && resource.data.compte_id == request.auth.uid;
      allow write: if false;
    }

    // ─── purchases ───────────────────────────────────────────────────────────
    // Données brutes Selar — gérées exclusivement par Cloud Functions.
    // Contient email client, montant, statut — jamais exposé au client.
    match /purchases/{purchaseId} {
      allow read, write: if false;
    }

    // ─── forum_posts ──────────────────────────────────────────────────────────
    match /forum_posts/{postId} {
      // Lire : tout utilisateur authentifié
      allow read: if request.auth != null;
      // Créer : tout utilisateur authentifié (auteur = request.auth.uid)
      // Les champs obligatoires sont validés ici
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.keys().hasAll(['authorId', 'content', 'createdAt'])
                    && request.resource.data.content is string
                    && request.resource.data.content.size() > 0
                    && request.resource.data.content.size() <= 5000;
      // Modifier/Supprimer : seulement l'auteur ou un admin
      allow update, delete: if request.auth != null
                            && (resource.data.authorId == request.auth.uid
                                || request.auth.token.isAdmin == true);
    }

    // ─── forum_replies ────────────────────────────────────────────────────────
    match /forum_replies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.keys().hasAll(['authorId', 'content', 'createdAt'])
                    && request.resource.data.content is string
                    && request.resource.data.content.size() > 0
                    && request.resource.data.content.size() <= 2000;
      allow update, delete: if request.auth != null
                            && (resource.data.authorId == request.auth.uid
                                || request.auth.token.isAdmin == true);
    }

    // ─── Default ──────────────────────────────────────────────────────────────
    // Firestore denies by default; all unlisted collections are implicitly denied.
  }
}

